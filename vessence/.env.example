# ═══════════════════════════════════════════════════════════════════════════════
# Vessence — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains your API keys.
#
# Minimal setup (everything else is optional):
#   GOOGLE_API_KEY   — required, powers Amber + Jane on Gemini
#   USER_NAME        — required, how Jane and Amber address you
#
# ═══════════════════════════════════════════════════════════════════════════════

# Optional host paths for split-root deployment.
# Leave blank to use local folders beside docker-compose.yml.
VESSENCE_DATA_HOME=
VAULT_HOME=


# ── Required ──────────────────────────────────────────────────────────────────

# Google Gemini API key — powers Amber, Jane (Gemini mode), and memory synthesis
# Get one free at: https://aistudio.google.com → Get API key → Create API key
# Looks like: AIzaSy... (39 characters)
GOOGLE_API_KEY=

# Your first name — Amber and Jane will use this to address you
USER_NAME=


# ── Jane's Brain ──────────────────────────────────────────────────────────────

# Which CLI powers Jane? Options: gemini (default, free), claude, openai
# Gemini mode uses GOOGLE_API_KEY above — no extra key needed.
JANE_BRAIN=gemini

# Web permission gate — set to 1 to require user approval for tool calls on the web UI
# When enabled, Bash/Write/Edit calls show approve/deny dialogs in the chat
JANE_WEB_PERMISSIONS=0

# Anthropic API key — required only if JANE_BRAIN=claude
# Get one at: https://console.anthropic.com → API Keys → Create Key
# Looks like: sk-ant-api03-...
ANTHROPIC_API_KEY=

# OpenAI API key — required only if JANE_BRAIN=openai
# Get one at: https://platform.openai.com/api-keys → Create new secret key
# Looks like: sk-proj-...
OPENAI_API_KEY=


# ── Web UI Security ───────────────────────────────────────────────────────────

# Secret key for session cookies
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=changeme-generate-a-real-secret

# Web UI login password (protects vault.localhost and jane.localhost)
# Set during onboarding — leave blank to be prompted on first login
VAULT_PASSWORD=

# Optional Google OAuth for browser sign-in.
# If left blank, the web UIs show one-time-code login only.
# Redirect URIs must include:
#   http://vault.localhost/auth/google/callback
#   http://jane.localhost/auth/google/callback
#   https://vault.yourdomain.com/auth/google/callback
#   https://jane.yourdomain.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional explicit public origins for OAuth redirects when running behind a
# reverse proxy or CDN. Set these if Google sign-in redirects to http:// or
# the wrong hostname.
VAULT_PUBLIC_BASE_URL=
JANE_PUBLIC_BASE_URL=

# Comma-separated allowlist for Google sign-in.
# Example: you@example.com,other@example.com
ALLOWED_GOOGLE_EMAILS=


# ── Cloudflare Tunnel (optional — for external access) ────────────────────────

# Without this, Vessence works at vault.localhost and jane.localhost only.
# With it, you get a permanent public URL at your own domain.
#
# Setup:
#   1. dash.cloudflare.com → Zero Trust → Networks → Tunnels → Create tunnel
#   2. Name it "vessence" → choose "cloudflared" → copy the token from the install command
#
# If you skip this, Vessence uses a free trycloudflare.com quick-tunnel instead
# (URL changes every restart but requires no setup or domain).
CLOUDFLARE_TUNNEL_TOKEN=

# Your domain configured in the Cloudflare tunnel (e.g. example.com)
# Vault will be at vault.yourdomain.com, Jane at jane.yourdomain.com
CLOUDFLARE_DOMAIN=


# ── Discord Bot (optional) ────────────────────────────────────────────────────

# Talk to Amber via Discord on your phone.
# Setup: discord.com/developers → New Application → Bot → Reset Token
DISCORD_TOKEN=

# The Discord channel ID where Amber posts (right-click channel → Copy Channel ID)
# Requires Developer Mode: Discord Settings → Advanced → Developer Mode
DISCORD_CHANNEL_ID=


# ── Ollama / Local LLM (optional — offline fallback) ─────────────────────────

# Enables offline fallback and local memory synthesis without sending data to Google.
# Install from https://ollama.com, then: ollama pull qwen2.5-coder:14b
# host.docker.internal reaches Ollama running on the host machine
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434
LOCAL_LLM_MODEL=qwen2.5-coder:14b


# ── Internal (don't change unless you know why) ───────────────────────────────

CHROMADB_HOST=chromadb
CHROMADB_PORT=8000
# ADK_SERVER_URL=http://amber:8000  # Amber is not in the Docker deployment

# Tavily web search API key (optional — falls back to DuckDuckGo without it)
# Free tier at: https://tavily.com
TAVILY_API_KEY=
